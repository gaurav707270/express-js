<!DOCTYPE html>
<html>
<head>
    <title>User List</title>
</head>
<body>

    <h1>Users </h1>

    <% userList.forEach((user) => { %>

        <div style="border:1px solid #000; margin:10px; padding:10px;">
            <h3><%= user.name %></h3>
            <p>Email: <%= user.email %></p>
        </div>

    <% }) %>

</body>
</html>